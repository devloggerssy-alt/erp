// ─── Stock Movement Type ──────────────────────────────────────────────────────
enum StockMovementType {
    OPENING
    PURCHASE
    SALE
    ADJUSTMENT
    STOCK_COUNT
    TRANSFER_IN
    TRANSFER_OUT
}

// ─── Stock Balance (projection table for fast reads) ─────────────────────────
model StockBalance {
    id          String   @id @default(uuid())
    tenantId    String
    warehouseId String
    itemId      String
    quantity    Decimal  @default(0) @db.Decimal(18, 4)
    averageCost Decimal  @default(0) @db.Decimal(18, 4)
    updatedAt   DateTime @updatedAt

    warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
    item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

    @@unique([tenantId, warehouseId, itemId])
    @@index([tenantId])
    @@map("stock_balances")
}

// ─── Stock Movement (source of truth ledger) ─────────────────────────────────
model StockMovement {
    id             String            @id @default(uuid())
    tenantId       String
    warehouseId    String
    itemId         String
    fiscalPeriodId String
    movementType   StockMovementType
    quantity       Decimal           @db.Decimal(18, 4)
    unitCost       Decimal           @default(0) @db.Decimal(18, 4)
    referenceType  String?           // e.g. "invoice", "stock_count"
    referenceId    String?
    notes          String?
    createdAt      DateTime          @default(now())
    createdBy      String

    warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
    item         Item         @relation(fields: [itemId], references: [id])
    fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id])

    @@index([tenantId])
    @@index([tenantId, itemId])
    @@index([tenantId, warehouseId])
    @@map("stock_movements")
}
