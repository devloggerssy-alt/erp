{
    "name": "@devloggers/contracts",
    "version": "0.0.1",
    "description": "Database package with Prisma schema and generated client",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./client": {
            "types": "./dist/client.d.ts",
            "import": "./dist/client.js",
            "require": "./dist/client.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@devloggers/db-prisma": "workspace:*"
    },
    "devDependencies": {
        "@devloggers/typescript-config": "workspace:*",
        "@types/node": "^22.0.0",
        "prisma": "^6.7.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3"
    }
}